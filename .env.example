# Copy this file to .env and fill in your values.
# Never commit .env to git.

# Neon Postgres — ask a maintainer for credentials, or provision your own
# and run db/01_schema.sql against it.
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Optional — only needed if you re-run the Claude Code CLI-based scorers
# (13_llm_agent_scorer.py). If not set, LLM-scorer runs will be skipped.
# ANTHROPIC_API_KEY=sk-ant-...
